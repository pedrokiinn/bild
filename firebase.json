{
  "functions": [
    {
      "codebase": "default",
      "source": "src/functions",
      "runtime": "nodejs18"
    },
    {
      "source": "]JavaScript",
      "codebase": "carcheck-gkeh4",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  }
}