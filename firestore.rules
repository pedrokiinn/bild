rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      // Impede escalonamento de privilégios: Usuário só cria o próprio perfil como 'collaborator'
      allow create: if request.auth != null && request.auth.uid == userId && request.resource.data.role == 'collaborator';
      // Apenas admins mudam cargos. Usuários mudam o próprio perfil mas não o próprio cargo.
      allow update: if request.auth != null && (isAdmin() || (request.auth.uid == userId && request.resource.data.role == resource.data.role));
      allow delete: if false; 
    }
    
    match /users {
      allow list: if request.auth != null;
    }

    match /vehicles/{vehicleId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    match /checklists/{checklistId} {
        allow read: if request.auth != null;
        // Valida que o driverId da criação corresponde ao usuário autenticado
        allow create: if request.auth != null && request.resource.data.driverId == request.auth.uid;
        allow update: if request.auth != null && (isAdmin() || resource.data.driverId == request.auth.uid);
        allow delete: if request.auth != null && isAdmin();
    }
    
    match /deletionReports/{reportId} {
        allow read, write: if request.auth != null && isAdmin();
    }
  }
}