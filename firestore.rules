rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function getUserRole(userId) {
      let userDoc = get(/databases/$(database)/documents/users/$(userId));
      return userDoc != null ? userDoc.data.role : 'collaborator';
    }

    match /users/{userId} {
      allow read: if request.auth != null && (getUserRole(request.auth.uid) == 'admin' || request.auth.uid == userId);
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && getUserRole(request.auth.uid) == 'admin';
      allow delete: if request.auth != null && getUserRole(request.auth.uid) == 'admin';
    }

    match /vehicles/{vehicleId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && getUserRole(request.auth.uid) == 'admin';
    }

    match /carretas/{carretaId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && getUserRole(request.auth.uid) == 'admin';
    }

    match /checklists/{checklistId} {
        allow read: if request.auth != null && (getUserRole(request.auth.uid) == 'admin' || resource.data.driverId == request.auth.uid);
        allow create: if request.auth != null;
        allow update: if request.auth != null && (getUserRole(request.auth.uid) == 'admin' || resource.data.driverId == request.auth.uid);
        allow delete: if request.auth != null && getUserRole(request.auth.uid) == 'admin';
    }
    
    match /deletionReports/{reportId} {
        allow read, write: if request.auth != null && getUserRole(request.auth.uid) == 'admin';
    }
  }
}